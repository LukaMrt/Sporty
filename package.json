{
  "name": "sporty",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "c8 node ace test --force-exit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise app --config .dependency-cruiser.cjs",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run depcruise && pnpm run test",
    "db:migrate": "node ace migration:run",
    "db:migrate:rollback": "node ace migration:rollback",
    "db:migrate:fresh": "node ace migration:fresh",
    "db:seed": "node ace db:truncate && node ace db:seed"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#repositories/*": "./app/repositories/*.js",
    "#use_cases/*": "./app/use_cases/*.js",
    "#domain/*": "./app/domain/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/eslint-config": "~3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "~2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^4.0.0",
    "@japa/runner": "~4.5.0",
    "@swc/core": "1.15.13",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "c8": "^10.1.3",
    "dependency-cruiser": "^17.3.8",
    "eslint": "~9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "ts-node-maintained": "^10.9.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "~6.4.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.6.0",
    "@adonisjs/core": "^6.21.0",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/inertia": "^3.1.1",
    "@adonisjs/lucid": "^21.8.2",
    "@adonisjs/session": "^7.7.1",
    "@adonisjs/shield": "^8.2.0",
    "@adonisjs/static": "^1.1.1",
    "@adonisjs/vite": "^4.0.0",
    "@inertiajs/react": "^2.3.17",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@vinejs/vine": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "edge.js": "^6.5.0",
    "lucide-react": "~0.575.0",
    "luxon": "^3.7.2",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.5.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "c8": {
    "reporter": [
      "html"
    ],
    "include": [
      "app/**"
    ],
    "extension": [
      ".ts",
      ".js"
    ],
    "all": true,
    "reportsDirectory": "coverage"
  },
  "prettier": "@adonisjs/prettier-config",
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
}
