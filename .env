TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
# Générer une nouvelle clé en production : node ace generate:key
APP_KEY=aazeaze78az1dqs5d47a65zd1qsd47
NODE_ENV=development
SESSION_DRIVER=cookie

# =============================================================================
# Base de données PostgreSQL
# Valeurs par défaut pour le développement local.
#
# Pour surcharger sans versionner : créer un fichier .env.local
# (déjà ignoré par git). Exemple : DB_HOST=localhost DB_PORT=5433
#
# Note : quand l'app tourne dans Docker (docker compose up app),
#        DB_HOST est automatiquement surchargé à "db" (nom du service).
#        Quand elle tourne en local (node ace serve --hmr),
#        DB_HOST doit être "localhost".
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=sporty
DB_PASSWORD=sporty
DB_DATABASE=sporty
