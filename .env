TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Generate a new key for production: node ace generate:key
APP_KEY=aazeaze78az1dqs5d47a65zd1qsd47

# =============================================================================
# PostgreSQL database
# Default values for local development.
#
# To override without versioning: create a .env.local file
# (already ignored by git). Example: DB_HOST=localhost DB_PORT=5433
#
# Note: when the app runs inside Docker (docker compose up app),
#       DB_HOST is automatically overridden to "db" (service name).
#       When running locally (node ace serve --hmr),
#       DB_HOST must be "localhost".
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=sporty
DB_PASSWORD=sporty
DB_DATABASE=sporty

# =============================================================================
# Connector token encryption (AES-256-GCM)
# Generate a real key for production: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
CONNECTOR_ENCRYPTION_KEY=demo-key-change-in-production-32b

# =============================================================================
# Strava OAuth connector
# Register your app at https://www.strava.com/settings/api
# APP_URL is used to build the redirect_uri (default: http://HOST:PORT)
# =============================================================================
APP_URL=http://localhost:3333
STRAVA_CLIENT_ID=strava-client-id-change-in-production
STRAVA_CLIENT_SECRET=strava-client-secret-change-in-production

